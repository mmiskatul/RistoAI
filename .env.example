# RistoAI application identity
APP_NAME=RistoAI
APP_VERSION=1.0.0
DEBUG=true
TESTING=false

# MongoDB Atlas connection
# Replace the placeholders with your own Atlas driver connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=RistoAI
DATABASE_NAME=ristoai

# JWT authentication
# Generate a strong random secret for production.
JWT_SECRET=change-this-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7

# Frontend origins allowed by CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# AI chat provider
# Use 'mock' for local fallback or 'huggingface' for transformers-based chat.
AI_CHAT_PROVIDER=mock
AI_CHAT_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
AI_CHAT_MAX_NEW_TOKENS=256
AI_CHAT_TEMPERATURE=0.2
HUGGINGFACE_TOKEN=

# SMTP / email settings
# If SMTP_ENABLED=true, SMTP_HOST, SMTP_USERNAME, SMTP_PASSWORD,
# and SMTP_FROM_EMAIL are required by the settings validator.
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=RistoAI
SMTP_USE_TLS=true
SMTP_USE_SSL=false
