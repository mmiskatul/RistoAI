# RistoAI application identity
APP_NAME=RistoAI
APP_VERSION=1.0.0
DEBUG=true
TESTING=false
LOG_LEVEL=ERROR
REQUEST_LOGS_ENABLED=false

# MongoDB Atlas connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=RistoAI
DATABASE_NAME=ristoai

# JWT authentication
JWT_SECRET=change-this-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7

# Frontend origins allowed by CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# SMTP / email settings
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=RistoAI
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Bootstrap super admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=password123
SUPER_ADMIN_FULL_NAME=Admin User

# Bootstrap singleton subscription plan
SUBSCRIPTION_PLAN_NAME=Core Plan
SUBSCRIPTION_PLAN_MONTHLY_PRICE=30
SUBSCRIPTION_PLAN_ANNUAL_PRICE=350
SUBSCRIPTION_PLAN_TRIAL_DAYS=7
SUBSCRIPTION_PLAN_FEATURES=["AI menu suggestions","Basic sales analytics","Email support"]
SUBSCRIPTION_PLAN_IS_VISIBLE=true
SUBSCRIPTION_PLAN_IS_ACTIVE=true
SUBSCRIPTION_PLAN_IS_BEST=false

# OpenAI settings for client document extraction and chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

